---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="min-h-screen bg-gray-100 py-[90px] px-5">
    <div class="mx-auto max-w-2xl rounded-3xl border border-gray-200 bg-white px-14 py-[70px] shadow-lg md:px-14">
      <h1 class="mb-[18px] text-center text-2xl font-medium tracking-wide text-gray-900">
        Votre inscription est confirmée
      </h1>

      <div class="mx-auto mb-6 h-0.5 w-14 rounded bg-gray-600"></div>

      <p class="mb-6 text-center text-sm font-light leading-7 text-gray-600">
        Merci pour votre inscription à notre lettre d'information.<br /><br />
        Vous recevrez désormais les actualités, annonces et événements de Villa Sonneville.
      </p>

      <div class="text-center">
        <a
          href="/"
          class="inline-block rounded-full bg-gray-600 px-7 py-3 text-xs font-medium tracking-tight text-white transition-colors duration-300 hover:bg-gray-700"
        >
          Retour au site
        </a>
      </div>

      <div class="mt-9 text-center text-sm font-normal tracking-tight text-gray-900">
        Villa Sonneville
      </div>
    </div>
  </div>
</BaseLayout>
